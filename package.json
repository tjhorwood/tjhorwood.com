    "tsx": "^4.23.1"
  },
  "name": "tjhorwood",
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@tailwindcss/oxide",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "dompurify": "^3.4.11",
      "esbuild": "^0.25.12",
      "postcss": "^8.5.19"
    }
  },
  "private": true,
  "scripts": {
    "build": "next build --webpack",
    "check": "biome check --write src scripts biome.json components.json package.json tsconfig.json next.config.mjs postcss.config.mjs",
    "dev": "next dev --turbopack -p 3031",
    "docker:build": "docker compose -f compose.yml build",
    "docker:deploy": "docker compose -f compose.yml up -d",
    "format": "biome format --write .",
    "generate:importmap": "payload generate:importmap && biome check --write src/app/\\(payload\\)/admin/importMap.js",
    "generate:types": "payload generate:types && biome check --write src/payload-types.ts",
    "import:blog": "tsx scripts/import/importBlogPost.ts",
    "import:projects": "tsx scripts/import/importProjects.ts",
    "lint": "biome check src scripts biome.json components.json package.json tsconfig.json next.config.mjs postcss.config.mjs",
    "migrate": "payload migrate",
    "migrate:create": "payload migrate:create",
    "migrate:status": "payload migrate:status",
    "payload": "payload",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "version": "0.1.0"
}
