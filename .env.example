# Local Payload CMS / Next.js settings
DATABASE_URI=postgres://payload:payload@localhost:5432/tjhorwood_payload
PAYLOAD_SECRET=replace-with-a-long-random-secret
NEXT_PUBLIC_SITE_URL=http://localhost:3031

# Docker/LXC deployment settings
POSTGRES_DB=tjhorwood_payload
POSTGRES_USER=payload
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Preview/revalidation placeholders for later phases
PREVIEW_SECRET=replace-with-a-long-random-secret
REVALIDATION_SECRET=replace-with-a-long-random-secret

# Import safety placeholders for later phases
IMPORT_ENVIRONMENT=local
ALLOW_PRODUCTION_IMPORT=false

# S3-compatible media storage via Garage
S3_ENABLED=true
S3_BUCKET=tjhorwood-media
S3_REGION=garage
S3_ENDPOINT=http://garage:3900
S3_ACCESS_KEY_ID=tjhorwood-payload
S3_SECRET_ACCESS_KEY=replace-with-s3-secret-key
GARAGE_RPC_SECRET=replace-with-64-char-hex-rpc-secret
GARAGE_ADMIN_TOKEN=replace-with-garage-admin-token
GARAGE_METRICS_TOKEN=replace-with-garage-metrics-token
